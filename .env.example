# Copy to .env, keep that file mode 0600, and never commit it.  This template
# contains placeholders only; a real auth key/API key is credential material.
#
# Tailscale identity is used only by the web/Tailscale deployment, never by the
# air-gapped CLI path.  The node identity persists in the named `apptsdata`
# volume after its first registration.
TS_AUTHKEY=tskey-auth-REPLACE-ME
# Version-pinned default.  For a production promotion, replace this with the
# reviewed `tailscale/tailscale@sha256:...` manifest digest.
TAILSCALE_IMAGE=tailscale/tailscale:v1.98

# Linux bind-mount ownership.  Before `docker compose up`, set these to
# `id -u` and `id -g` for the account that owns ./data (1000 is a common local
# default).  The container never runs as UID 0.
APP_UID=1000
APP_GID=1000

# --- Web authentication (required for production) ---
# Token mode is the default. Set a high-entropy secret and the server-derived
# actor/roles as JSON; leave no known placeholder value here. Example shape:
# CSDH_AUTH_TOKENS_JSON={"a-unique-32-plus-character-secret":{"actor":"admin@example.com","roles":["admin"]}}
CSDH_AUTH_MODE=token
CSDH_AUTH_TOKENS_JSON=
# Use only with a reverse proxy that authenticates requests and removes any
# client-supplied copy of this header before injecting its trusted identity.
CSDH_TRUSTED_PROXY_USER_HEADER=X-CSDH-Authenticated-User
# Keep true for the Tailscale HTTPS deployment. Set false only for local HTTP
# development while CSDH_AUTH_MODE=disabled is explicitly understood.
CSDH_SESSION_COOKIE_SECURE=true

# --- LLM provider configuration ---
# `none` is the safe default: no provider key and no network egress for model
# calls.  `local` targets an OpenAI-compatible server.  `openai` and `gemini`
# send submitted evidence to a cloud provider only after the UI/API caller
# explicitly acknowledges that transfer.
LLM_PROVIDER=none
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LOCAL_LLM_BASE_URL=
LOCAL_LLM_MODEL=llama3.1
LOCAL_LLM_API_KEY=
# Bound each local/cloud model call. Graph-crawl progress and cancellation are
# checked between requests, so this also bounds the wait for an in-flight call.
LLM_REQUEST_TIMEOUT_SECONDS=90

# A provider can make a bounded, read-only crawl through opaque graph-tool
# handles. Each request emits progress before/after execution. Disable it only
# for an intentionally narrative-only provider run.
LLM_GRAPH_TOOL_CRAWL=enabled
LLM_GRAPH_TOOL_MAX_CALLS=6

# --- Durable web-run storage policy ---
# docker-compose.yml pins the in-container data directory to /app/data.  It
# contains SQLite/WAL, uploads, normalized observations, report revisions,
# exports, and soft-delete trash; protect and back up the host ./data directory.
CSDH_MAX_UPLOAD_BYTES=26214400
CSDH_MAX_TEXT_CHARACTERS=2000000
# Keep one worker unless the host has been capacity-tested.  A higher value
# means more concurrent graph/LLM work, not more Uvicorn processes.
CSDH_WORKER_CONCURRENCY=1
# 720 hours = 30 days.  It is the restore/undo window for soft-deleted reports;
# it is not an authorization policy or a substitute for backups.
CSDH_DELETE_RETENTION_HOURS=720
