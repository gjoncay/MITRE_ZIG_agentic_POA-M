# Copy to .env (gitignored) and paste the reusable Tailscale auth key.
# Reuse the key from another app's .env (e.g. ~/Projects/whoami/.env),
# or mint a new reusable key at https://login.tailscale.com/admin/settings/keys.
# Only used at first container start; the node then persists in the apptsdata volume.
TS_AUTHKEY=tskey-auth-REPLACE-ME

# --- App-level LLM provider config (UNRELATED to TS_AUTHKEY above) ---
# These are read by the app container itself (run_analyst_pipeline.py /
# scripts/llm_providers.py), not by Tailscale. Default is "none" so a fresh
# clone works with zero API keys and no network access required.
LLM_PROVIDER=none
OPENAI_API_KEY=
GEMINI_API_KEY=
LOCAL_LLM_BASE_URL=
